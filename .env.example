# NeaPay Complete - Environment Configuration Template

# ============================================================================
# GENERAL
# ============================================================================
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# ============================================================================
# DATABASE
# ============================================================================
DATABASE_URL=postgresql://neapay:password@localhost:5432/neapay
POSTGRES_USER=neapay
POSTGRES_PASSWORD=change-me-secure-password
POSTGRES_DB=neapay

# ============================================================================
# REDIS
# ============================================================================
REDIS_URL=redis://:password@localhost:6379
REDIS_PASSWORD=change-me-secure-password

# ============================================================================
# API CONFIGURATION
# ============================================================================
API_KEY=your-api-key-here
API_SECRET=your-api-secret-here
SECRET_KEY=your-secret-key-here

# ============================================================================
# FRONTEND
# ============================================================================
VITE_API_URL=http://localhost:3000
VITE_ENV=development

# ============================================================================
# MONITORING (Production Only)
# ============================================================================
GRAFANA_PASSWORD=change-me-secure-password

# ============================================================================
# AWS/S3 (For Backups - Optional)
# ============================================================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=neapay-backups

# ============================================================================
# SLACK (Optional)
# ============================================================================
SLACK_WEBHOOK_URL=
