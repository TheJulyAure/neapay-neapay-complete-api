# Example environment configuration for NeaPay Complete
# Copy this file to .env and fill in your actual values

# Frontend settings
FRONTEND_PORT=5173
FRONTEND_URL=http://localhost:5173

# API settings
API_PORT=3000
API_URL=http://localhost:3000

# Database
DATABASE_URL=./database/financial.db

# Development/Production mode
NODE_ENV=development
VITE_API_URL=http://localhost:3000

# JWT Secret (generate a strong random string for production)
JWT_SECRET=your-jwt-secret-here

# Stripe (if using Stripe integration)
STRIPE_PUBLIC_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Clover (if using Clover integration)
CLOVER_API_KEY=...
CLOVER_API_SECRET=...
CLOVER_ENVIRONMENT=sandbox

# Email (if using email notifications)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Logging
LOG_LEVEL=info
