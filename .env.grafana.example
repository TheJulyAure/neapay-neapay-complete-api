# Grafana Cloud Configuration
# Copy this file to .env and fill in your actual values

# Hosted Metrics (Prometheus) Configuration
GCLOUD_HOSTED_METRICS_ID=3049370
GCLOUD_HOSTED_METRICS_URL=https://prometheus-prod-67-prod-us-west-0.grafana.net/api/prom/push

# Hosted Logs (Loki) Configuration
GCLOUD_HOSTED_LOGS_ID=1520360
GCLOUD_HOSTED_LOGS_URL=https://logs-prod-021.grafana.net/loki/api/v1/push

# Fleet Management Configuration
GCLOUD_FM_URL=https://fleet-management-prod-014.grafana.net
GCLOUD_FM_POLL_FREQUENCY=60s
GCLOUD_FM_HOSTED_ID=1562571

# Server Architecture
ARCH=amd64

# REQUIRED: Add your Grafana Cloud API Key here
# Get your API key from: https://grafana.com/docs/grafana-cloud/account-management/authentication-and-authorization/create-api-token/
GCLOUD_RW_API_KEY=your_api_key_here
